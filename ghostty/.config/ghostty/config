# shell
command = shell:for fish in /opt/homebrew/bin/fish /usr/local/bin/fish /usr/bin/fish; do [ -x "$fish" ] && exec "$fish" -l; done; exec fish -l

# font
font-family = "Lilex Nerd Font"
font-style = Regular
font-style-bold = Medium
font-style-italic = Italic
font-style-bold-italic = Medium Italic
font-size = 11

# MacOS only font thickening
font-thicken = true
# 0-255
font-thicken-strength = 75

# cursor
shell-integration-features = no-cursor
cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = true

# window/theme
window-decoration = false
window-save-state = always
mouse-hide-while-typing = true
theme = Catppuccin Mocha

# Omarchy universal copy/paste support
shell-integration-features = no-cursor,ssh-env
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard

# Let terminal apps use these shortcuts instead of Ghostty splits
keybind = ctrl+shift+e=unbind
keybind = ctrl+shift+o=unbind

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
